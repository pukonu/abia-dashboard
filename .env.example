# ================================================================
# Abia State Dashboard — environment variables
# Copy to .env and fill in from your Supabase project settings.
# ================================================================

# --- Supabase API (Project Settings → API) ---------------------
# Used by the app to READ dashboard data in live mode.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Used by server actions to WRITE data (manage forms, CSV import)
# and upload evidence images to Storage. Keep secret — server only.
SUPABASE_SERVICE_ROLE_KEY=

# --- Prisma / Postgres (Project Settings → Database) ------------
# DATABASE_URL: pooled connection (port 6543, pgbouncer) — used at runtime.
# DIRECT_URL:   direct connection (port 5432) — used by `prisma migrate`.
DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# --- Evidence storage -------------------------------------------
# Name of the (public) Supabase Storage bucket for evidence images.
NEXT_PUBLIC_EVIDENCE_BUCKET=evidence

# --- AI assistant ------------------------------------------------
# Server-only key for the Governor's data assistant.
GEMINI_API_KEY=
# Default model for the assistant. Override if Google publishes a newer model id.
GEMINI_MODEL=gemini-3.1-flash-lite

# --- Weekly digest email (SendGrid) --------------------------------
# Public site URL used in unsubscribe links (no trailing slash).
NEXT_PUBLIC_APP_URL=http://localhost:7401
# SendGrid API key (https://app.sendgrid.com/settings/api_keys) — required to send Friday digests.
SENDGRID_API_KEY=
# From address (must be a verified sender/domain in SendGrid). Defaults to noreply@abiaworkspace.com.
DIGEST_FROM_EMAIL=Abia State Dashboard <noreply@abiaworkspace.com>
# Shared secret for /api/cron/weekly-digest (Vercel Cron uses Bearer auth).
CRON_SECRET=
