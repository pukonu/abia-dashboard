// Abia State Dashboard — Prisma schema
// Prisma is the migration tool for the Supabase Postgres database:
//   npx prisma migrate dev --name <change>   (development)
//   npx prisma migrate deploy                (production)
// Note: Supabase RLS policies are plain SQL — add them in a migration
// (see supabase/schema.sql for the reference policies).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Frequency {
  daily
  weekly
  monthly
  quarterly
  yearly

  @@map("frequency")
}

enum Direction {
  higher_is_better
  lower_is_better

  @@map("direction")
}

enum IndicatorScope {
  state
  entity

  @@map("indicator_scope")
}

enum IndicatorValueType {
  score
  percentage
  number

  @@map("indicator_value_type")
}

enum DashboardScope {
  sector
  lga

  @@map("dashboard_scope")
}

enum DashboardChartType {
  trend
  bar
  radar
  stat
  pie

  @@map("dashboard_chart_type")
}

model Sector {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug          String         @unique
  name          String
  description   String?
  icon          String?
  color         String?
  sortOrder     Int            @default(0) @map("sort_order")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz
  mdas          Mda[]
  thematicAreas ThematicArea[]
  dashboards    Dashboard[]
  facts         SectorFact[]

  @@map("sectors")
}

model Lga {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String      @unique
  zone       String?
  population Int?
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz
  entities   Entity[]
  dashboards Dashboard[]

  @@map("lgas")
}

model Mda {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sectorId     String   @map("sector_id") @db.Uuid
  name         String
  abbreviation String?
  description  String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  sector       Sector   @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  entities     Entity[]

  @@unique([sectorId, name])
  @@map("mdas")
}

model Entity {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mdaId       String   @map("mda_id") @db.Uuid
  lgaId       String   @map("lga_id") @db.Uuid
  name        String
  entityType  String?  @map("entity_type")
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  mda         Mda      @relation(fields: [mdaId], references: [id], onDelete: Cascade)
  lga         Lga      @relation(fields: [lgaId], references: [id], onDelete: Restrict)
  results     Result[]

  @@unique([mdaId, name])
  @@index([lgaId], map: "idx_entities_lga")
  @@index([mdaId], map: "idx_entities_mda")
  @@map("entities")
}

model ThematicArea {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sectorId          String    @map("sector_id") @db.Uuid
  name              String
  description       String?
  frequency         Frequency @default(quarterly)
  weight            Decimal   @default(1) @db.Decimal
  /// Marks this thematic area as the sector's executive dashboard (one per sector).
  /// Used for /manage/sector-dashboard entry and the weekly digest PDF.
  isSectorDashboard Boolean   @default(false) @map("is_sector_dashboard")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  sector            Sector    @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  domains           Domain[]

  @@unique([sectorId, name])
  @@map("thematic_areas")
}

model Domain {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  thematicAreaId String       @map("thematic_area_id") @db.Uuid
  name           String
  description    String?
  /// National comparison value, free text (e.g. "993 / 100,000 (UN MMEIG 2023)")
  benchmarkNigeria String?    @map("benchmark_nigeria")
  /// Official target, free text (e.g. "≤70 / 100,000")
  benchmarkTarget  String?    @map("benchmark_target")
  weight         Decimal      @default(1) @db.Decimal
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  thematicArea   ThematicArea @relation(fields: [thematicAreaId], references: [id], onDelete: Cascade)
  indicators     Indicator[]

  @@unique([thematicAreaId, name])
  @@map("domains")
}

model Indicator {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  domainId          String          @map("domain_id") @db.Uuid
  indicatorScope    IndicatorScope  @default(state) @map("indicator_scope")
  /// For entity indicators: which state-level indicator receives the rollup.
  stateIndicatorId  String?         @map("state_indicator_id") @db.Uuid
  name              String
  description       String?
  valueType         IndicatorValueType @default(number) @map("value_type")
  scoreOptions      Json?           @map("score_options")
  unit              String          @default("%")
  direction         Direction       @default(higher_is_better)
  targetValue       Decimal?        @map("target_value") @db.Decimal
  targetSource      String?         @map("target_source")
  weight            Decimal         @default(1) @db.Decimal
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz
  domain            Domain          @relation(fields: [domainId], references: [id], onDelete: Cascade)
  stateIndicator    Indicator?      @relation("IndicatorRollup", fields: [stateIndicatorId], references: [id], onDelete: SetNull)
  entityIndicators  Indicator[]     @relation("IndicatorRollup")
  results           Result[]

  @@unique([domainId, name, indicatorScope])
  @@index([stateIndicatorId], map: "idx_indicators_state_indicator")
  @@map("indicators")
}

model TimePeriod {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  frequency Frequency
  label     String
  startDate DateTime  @map("start_date") @db.Date
  endDate   DateTime  @map("end_date") @db.Date
  results   Result[]

  @@unique([frequency, startDate])
  @@map("time_periods")
}

model Result {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  indicatorId  String           @map("indicator_id") @db.Uuid
  timePeriodId String           @map("time_period_id") @db.Uuid
  entityId     String?          @map("entity_id") @db.Uuid
  abiaValue    Decimal          @map("abia_value") @db.Decimal
  nigeriaValue Decimal?         @map("nigeria_value") @db.Decimal
  targetValue  Decimal?         @map("target_value") @db.Decimal
  notes        String?
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime         @default(now()) @map("updated_at") @db.Timestamptz
  indicator    Indicator        @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  timePeriod   TimePeriod       @relation(fields: [timePeriodId], references: [id], onDelete: Cascade)
  entity       Entity?          @relation(fields: [entityId], references: [id], onDelete: Cascade)
  evidence     ResultEvidence[]

  @@index([indicatorId], map: "idx_results_indicator")
  @@index([timePeriodId], map: "idx_results_period")
  @@index([entityId], map: "idx_results_entity")
  @@map("results")
}

/// Evidence images backing a result, stored in the Supabase Storage
/// bucket named by NEXT_PUBLIC_EVIDENCE_BUCKET.
model ResultEvidence {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resultId    String   @map("result_id") @db.Uuid
  storagePath String   @map("storage_path")
  caption     String?
  uploadedAt  DateTime @default(now()) @map("uploaded_at") @db.Timestamptz
  result      Result   @relation(fields: [resultId], references: [id], onDelete: Cascade)

  @@index([resultId], map: "idx_result_evidence_result")
  @@map("result_evidence")
}

/// Admin-built custom dashboard, displayed on a sector or LGA page.
model Dashboard {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  scope       DashboardScope
  /// set when scope = sector
  sectorId    String?           @map("sector_id") @db.Uuid
  /// set when scope = lga
  lgaId       String?           @map("lga_id") @db.Uuid
  published   Boolean           @default(true)
  sortOrder   Int               @default(0) @map("sort_order")
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz
  sector      Sector?           @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  lga         Lga?              @relation(fields: [lgaId], references: [id], onDelete: Cascade)
  widgets     DashboardWidget[]

  @@index([sectorId], map: "idx_dashboards_sector")
  @@index([lgaId], map: "idx_dashboards_lga")
  @@map("dashboards")
}

/// One chart on a dashboard: a chart type plus the indicators it plots.
model DashboardWidget {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dashboardId  String             @map("dashboard_id") @db.Uuid
  chartType    DashboardChartType @map("chart_type")
  title        String?
  /// JSON array of indicator ids plotted by this widget
  indicatorIds Json               @default("[]") @map("indicator_ids")
  /// grid columns occupied (1 = half width, 2 = full width)
  span         Int                @default(1)
  position     Int                @default(0)
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz
  dashboard    Dashboard          @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([dashboardId], map: "idx_dashboard_widgets_dashboard")
  @@map("dashboard_widgets")
}

/// Manual executive facts displayed on sector landing pages.
model SectorFact {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sectorId  String   @map("sector_id") @db.Uuid
  label     String
  value     String
  caption   String?
  source    String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz
  sector    Sector   @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  @@index([sectorId], map: "idx_sector_facts_sector")
  @@map("sector_facts")
}

/// Public weekly digest subscribers (email-only signup).
/// Not exposed via public RLS — reads/writes use the service role.
model DigestSubscription {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email             String    @unique
  name              String?
  unsubscribeToken  String    @unique @default(dbgenerated("gen_random_uuid()")) @map("unsubscribe_token") @db.Uuid
  subscribedAt      DateTime  @default(now()) @map("subscribed_at") @db.Timestamptz
  unsubscribedAt    DateTime? @map("unsubscribed_at") @db.Timestamptz
  lastSentAt        DateTime? @map("last_sent_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([unsubscribedAt], map: "idx_digest_subscriptions_active")
  @@map("digest_subscriptions")
}
